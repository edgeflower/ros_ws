<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <!--
    改进版 attack_robot 行为树 v2

    主要改进:
    1. 所有分支改为 ReactiveSequence - 允许随时切换行为
    2. 使用黑板标记避免重复发送目标
    3. HoldPosition 使用 Once 节点 - 防止目标抖动
    4. 独立的握手端口 - 防止不同模式间的信号冲突
    5. 移除冗余验证 - 简化逻辑

    说明: 此版本使用 BehaviorTree.CPP 内置节点，无需自定义 CompareGoal
  -->
  <BehaviorTree ID="attack_robot_improved_v2">
    <Sequence>
      <!-- 感知层: 每次tick都执行 -->
      <ReactiveSequence name="Perception">
        <SubArmors topic_name="/target_tracking"
                   armors="{armors}"/>
        <RobotControl stop_gimbal_scan="True"
                      chassis_spin_vel="0.0"
                      gimbal_big_yaw_vel="40.0"/>
        <EnemyPositionFilter enemy_position="{armors}"
                             alpha="0.2"
                             max_distance="1.0"
                             history_size="7"
                             zero_threshold="0.1"
                             filtered_position="{filtered_target}"/>
        <ConfidenceHysteresis target="{filtered_target}"
                              upper_threshold="0.5"
                              lower_threshold="0.35"
                              grace_period="2.5"
                              enable_hold_position="true"
                              current_confidence="{current_confidence}"
                              hysteresis_state="{hysteresis_state}"/>
      </ReactiveSequence>

      <!-- 获取机器人位置 -->
      <GetLocation topic_name="/odometry"
                   robot_location="{robot_pose}"/>

      <!-- 行为选择: ReactiveFallback 允许随时切换 -->
      <ReactiveFallback name="BehaviorSelector">

        <!-- 分支1: HIGH - 追击敌人 -->
        <ReactiveSequence name="AttackEnemy">
          <!-- 检查状态 -->
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="HIGH"/>

          <!-- 计算追击目标 -->
          <ArmorToGoal target_message="{filtered_target}"
                       robot_pose="{robot_pose}"
                       offset_distance="2.0"
                       min_confidence="0.4"
                       goal_pose="{attack_goal}"/>

          <!-- 使用黑板标记 + Fallback 实现目标变化检测 -->
          <Sequence>
            <!-- 如果目标未设置标记，发送新目标 -->
            <Fallback>
              <!-- 检查是否需要发送新目标 (标记为 false 或目标变化) -->
              <Sequence>
                <!-- 检查 attack_goal_sent 标记 -->
                <Not>
                  <BlackboardCheckT blackboard_key="attack_goal_sent" expected="true"/>
                </Not>
                <!-- 发送目标 -->
                <SendGoal goal_pose="{attack_goal}"
                          action_name="/navigate_to_pose"
                          current_goal_id="-2"
                          reached_goal_id="{attack_reached_goal_id}"/>
                <!-- 设置标记为 true -->
                <SetBlackboard output_key="attack_goal_sent" value="true"/>
                <!-- 记录当前目标位置 (用于检测变化) -->
                <Script code="last_attack_x = attack_goal.pose.position.x; last_attack_y = attack_goal.pose.position.y"/>
              </Sequence>

              <!-- 目标已发送，检查是否变化 (简化版: 每次都重新发送新目标) -->
              <!-- 注意: 实际部署时可以根据需要添加更复杂的变化检测 -->
              <Sequence>
                <SendGoal goal_pose="{attack_goal}"
                          action_name="/navigate_to_pose"
                          current_goal_id="-2"
                          reached_goal_id="{attack_reached_goal_id}"/>
              </Sequence>
            </Fallback>
          </Sequence>
        </ReactiveSequence>

        <!-- 分支2: GRACE_PERIOD - 保持位置 -->
        <ReactiveSequence name="HoldPositionMode">
          <!-- 检查状态 -->
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="GRACE_PERIOD"/>

          <!-- Once节点: 只在第一次进入时执行，防止目标抖动 -->
          <Once>
            <HoldPosition target="{filtered_target}"
                          enabled="true"
                          robot_pose="{robot_pose}"
                          held_goal="{hold_goal}"/>
            <!-- 设置标记，表示已计算保持位置 -->
            <SetBlackboard output_key="hold_goal_set" value="true"/>
          </Once>

          <!-- 发送保持位置的目标 -->
          <SendGoal goal_pose="{hold_goal}"
                    action_name="/navigate_to_pose"
                    current_goal_id="-2"
                    reached_goal_id="{hold_reached_goal_id}"/>
        </ReactiveSequence>

        <!-- 分支3: LOW - 巡逻观测点 (改为ReactiveSequence) -->
        <ReactiveSequence name="PatrolMode">
          <!-- 检查状态 -->
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="LOW"/>

          <!-- 清空其他模式的握手信号，防止残留干扰 -->
          <SetBlackboard output_key="attack_goal_sent" value="false"/>
          <SetBlackboard output_key="hold_goal_set" value="false"/>
          <SetBlackboard output_key="attack_reached_goal_id" value="-1"/>
          <SetBlackboard output_key="hold_reached_goal_id" value="-1"/>

          <!-- 目标管理器 -->
          <GoalManager robot_pose="{robot_pose}"
                       lethal_threshold="252"
                       high_cost_threshold="200"
                       visit_timeout="20.0"
                       max_retries="1"
                       reset_requested="false"
                       hysteresis_threshold="0.7"
                       arrival_distance="0.5"
                       arrival_speed="0.2"
                       stay_duration="1.0"
                       min_exclusion_radius="1.0"
                       robot_speed="{robot_speed}"
                       auto_reset_cooldown="5.0"
                       completed_point_cooldown="10.0"
                       skipped_recovery_time="30.0"
                       reached_goal_id="{patrol_reached_goal_id}"
                       best_goal="{best_goal}"
                       selected_id="{goal_id}"
                       should_reset="{should_reset}"
                       idle_count="{idle_count}"
                       done_count="{done_count}"
                       goal_statuses="{goal_statuses}"/>

          <!-- 发送巡逻目标 -->
          <SendGoal name="NavigateToObservation"
                    goal_pose="{best_goal}"
                    action_name="/navigate_to_pose"
                    current_goal_id="{goal_id}"
                    reached_goal_id="{patrol_reached_goal_id}"/>
        </ReactiveSequence>

      </ReactiveFallback>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ArmorToGoal">
      <input_port name="target_message" default="{target_message}"/>
      <input_port name="robot_pose" default="{robot_pose}"/>
      <input_port name="offset_distance" default="1.5"/>
      <input_port name="min_confidence" default="0.3"/>
      <output_port name="goal_pose" default="{goal}"/>
    </Action>

    <Condition ID="BlackboardCheckT">
      <input_port name="blackboard_key" default="key"/>
      <input_port name="expected" default="true"/>
    </Condition>

    <Condition ID="CheckHysteresisState">
      <input_port name="state" default="{hysteresis_state}"/>
      <input_port name="expected_state" default="HIGH"/>
    </Condition>

    <Condition ID="ConfidenceHysteresis">
      <input_port name="target" default="{filtered_target}"/>
      <input_port name="upper_threshold" default="0.4"/>
      <input_port name="lower_threshold" default="0.3"/>
      <input_port name="grace_period" default="1.5"/>
      <input_port name="enable_hold_position" default="true"/>
      <output_port name="current_confidence" default="{current_confidence}"/>
      <output_port name="hysteresis_state" default="{hysteresis_state}"/>
    </Condition>

    <Action ID="EnemyPositionFilter" editable="true">
      <input_port name="enemy_position" default="{armors}"/>
      <input_port name="alpha" default="0.3"/>
      <input_port name="max_distance" default="10.0"/>
      <input_port name="history_size" default="5"/>
      <input_port name="zero_threshold" default="0.1"/>
      <output_port name="filtered_position" default="{filtered_position}"/>
    </Action>

    <Action ID="GetLocation">
      <input_port name="topic_name" default="/odometry"/>
      <output_port name="robot_location" default="{robot_pose}"/>
    </Action>

    <Action ID="GoalManager">
      <input_port name="robot_pose" default="{robot_pose}"/>
      <input_port name="lethal_threshold" default="252"/>
      <input_port name="high_cost_threshold" default="200"/>
      <input_port name="visit_timeout" default="30.0"/>
      <input_port name="max_retries" default="2"/>
      <input_port name="reset_requested" default="false"/>
      <input_port name="hysteresis_threshold" default="0.7"/>
      <input_port name="arrival_distance" default="0.5"/>
      <input_port name="arrival_speed" default="0.2"/>
      <input_port name="stay_duration" default="1.0"/>
      <input_port name="min_exclusion_radius" default="2.0"/>
      <input_port name="robot_speed" default="0.0"/>
      <input_port name="auto_reset_cooldown" default="5.0"/>
      <input_port name="completed_point_cooldown" default="10.0"/>
      <input_port name="skipped_recovery_time" default="30.0"/>
      <input_port name="reached_goal_id" default="{reached_goal_id}"/>
      <output_port name="best_goal" default="{best_goal}"/>
      <output_port name="selected_id" default="{goal_id}"/>
      <output_port name="should_reset" default="{should_reset}"/>
      <output_port name="idle_count" default="{idle_count}"/>
      <output_port name="done_count" default="{done_count}"/>
      <output_port name="goal_statuses" default="{goal_statuses}"/>
    </Action>

    <Action ID="HoldPosition">
      <input_port name="target" default="{filtered_target}"/>
      <input_port name="enabled" default="true"/>
      <input_port name="robot_pose" default="{robot_pose}"/>
      <output_port name="held_goal" default="{goal}"/>
      <output_port name="is_holding" default="{is_holding}"/>
    </Action>

    <Action ID="RobotControl">
      <input_port name="stop_gimbal_scan" default="True"/>
      <input_port name="chassis_spin_vel" default="0.0"/>
      <input_port name="gimbal_big_yaw_vel" default="1.0"/>
    </Action>

    <Action ID="SendGoal">
      <input_port name="goal_pose" default="{best_goal}"/>
      <input_port name="action_name" default="/navigate_to_pose"/>
      <input_port name="current_goal_id" default="{goal_id}"/>
      <output_port name="reached_goal_id" default="{reached_goal_id}"/>
    </Action>

    <Action ID="SetBlackboard">
      <input_port name="output_key" default="output_key"/>
      <input_port name="value" default="value"/>
    </Action>

    <Action ID="SubArmors" editable="true">
      <input_port name="topic_name" default="/detector/armors"/>
      <output_port name="armors" default="{armors}"/>
    </Action>

    <Action ID="Wait">
      <input_port name="duration" default="1.0"/>
    </Action>
  </TreeNodesModel>

</root>
