<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="attack_robot_improved_v2">
    <Sequence>
      <ReactiveSequence name="Perception">
        <SubArmors topic_name="/target_tracking"
                   armors="{armors}"/>
        <SubRobotStatus topic_name="/robot_status"
                        robot_status="{robot_status}"/>
        <RobotControl stop_gimbal_scan="True"
                      chassis_spin_vel="0.0"
                      gimbal_big_yaw_vel="40.0"
                      gimbal_big_yaw_angle="0.0"
                      follow_gimbal_big="true"
                      chassis_vel_multi="1.0"
                      stop_chassis_vel_multi="True"
                      track_status="false"/>
        <EnemyPositionFilter enemy_position="{armors}"
                             alpha="0.2"
                             max_distance="1.0"
                             history_size="7"
                             zero_threshold="0.1"
                             min_output_interval="0.1"
                             confidence_half_life="1.0"
                             min_confidence="0.0"
                             filtered_position="{filtered_target}"/>
        <ConfidenceHysteresis target="{filtered_target}"
                              upper_threshold="0.5"
                              lower_threshold="0.35"
                              grace_period="2.5"
                              enable_hold_position="true"
                              current_confidence="{current_confidence}"
                              hysteresis_state="{hysteresis_state}"/>
      </ReactiveSequence>
      <GetLocation topic_name="/odometry"
                   robot_location="{robot_pose}"/>
      <ReactiveFallback name="BehaviorSelector">
        <ReactiveSequence name="AttackEnemy">
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="HIGH"/>
          <IsStatusOK message="{robot_status}"
                      hp_threshold="150"
                      heat_threshold="300"
                      shot_threshold="10"/>
          <ArmorToGoal target_message="{filtered_target}"
                       robot_pose="{robot_pose}"
                       offset_distance="2.0"
                       predict_time="0.5"
                       max_chase_distance="10.0"
                       goal_pose="{attack_goal}"/>
          <ChaseGoal goal_pose="{attack_goal}"
                     action_name="/navigate_to_pose"
                     min_goal_distance="0.3"
                     max_resend_interval="2.0"
                     chase_timeout="15.0"
                     server_timeout="5.0"/>
        </ReactiveSequence>
        <ReactiveSequence name="HoldPositionMode">
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="GRACE_PERIOD"/>
          <Once>
            <HoldPosition target="{filtered_target}"
                          enabled="true"
                          robot_pose="{robot_pose}"
                          held_goal="{hold_goal}"
                          is_holding="{is_holding}"/>
            <SetBlackboard value="true"
                           output_key="hold_goal_set"/>
          </Once>
          <SendGoal goal_pose="{hold_goal}"
                    action_name="/navigate_to_pose"
                    min_goal_distance="0.5"
                    current_goal_id="-2"
                    reached_goal_id="{hold_reached_goal_id}"/>
        </ReactiveSequence>
        <ReactiveSequence name="PatrolMode">
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="LOW"/>
          <SetBlackboard value="false"
                         output_key="attack_goal_sent"/>
          <SetBlackboard value="false"
                         output_key="hold_goal_set"/>
          <SetBlackboard value="-1"
                         output_key="attack_reached_goal_id"/>
          <SetBlackboard value="-1"
                         output_key="hold_reached_goal_id"/>
          <GoalManager robot_pose="{robot_pose}"
                       lethal_threshold="252"
                       high_cost_threshold="200"
                       visit_timeout="20.0"
                       max_retries="1"
                       reset_requested="false"
                       hysteresis_threshold="0.7"
                       arrival_distance="0.5"
                       arrival_speed="0.2"
                       stay_duration="1.0"
                       min_exclusion_radius="1.0"
                       robot_speed="{robot_speed}"
                       auto_reset_cooldown="5.0"
                       completed_point_cooldown="10.0"
                       skipped_recovery_time="30.0"
                       reached_goal_id="{patrol_reached_goal_id}"
                       best_goal="{best_goal}"
                       selected_id="{goal_id}"
                       should_reset="{should_reset}"
                       idle_count="{idle_count}"
                       done_count="{done_count}"
                       goal_statuses="{goal_statuses}"/>
          <SendGoal name="NavigateToObservation"
                    goal_pose="{best_goal}"
                    action_name="/navigate_to_pose"
                    min_goal_distance="0.5"
                    current_goal_id="{goal_id}"
                    reached_goal_id="{patrol_reached_goal_id}"/>
        </ReactiveSequence>
      </ReactiveFallback>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ArmorToGoal">
      <input_port name="target_message"
                  default="{target_message}"/>
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <input_port name="offset_distance"
                  default="2.0"/>
      <input_port name="predict_time"
                  default="0.5"/>
      <input_port name="max_chase_distance"
                  default="10.0"/>
      <output_port name="goal_pose"
                   default="{goal}"/>
    </Action>
    <Action ID="ChaseGoal">
      <input_port name="goal_pose"
                  default="{attack_goal}"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="min_goal_distance"
                  default="0.3"/>
      <input_port name="max_resend_interval"
                  default="2.0"/>
      <input_port name="chase_timeout"
                  default="15.0"/>
      <input_port name="server_timeout"
                  default="5.0"/>
    </Action>
    <Condition ID="CheckHysteresisState">
      <input_port name="state"
                  default="{hysteresis_state}"/>
      <input_port name="expected_state"
                  default="HIGH"/>
    </Condition>
    <Condition ID="ConfidenceHysteresis">
      <input_port name="target"
                  default="{filtered_target}"/>
      <input_port name="upper_threshold"
                  default="0.4"/>
      <input_port name="lower_threshold"
                  default="0.3"/>
      <input_port name="grace_period"
                  default="1.5"/>
      <input_port name="enable_hold_position"
                  default="true"/>
      <output_port name="current_confidence"
                   default="{current_confidence}"/>
      <output_port name="hysteresis_state"
                   default="{hysteresis_state}"/>
    </Condition>
    <Action ID="EnemyPositionFilter"
            editable="true">
      <input_port name="enemy_position"
                  default="{armors}"/>
      <input_port name="alpha"
                  default="0.3"/>
      <input_port name="max_distance"
                  default="1.5"/>
      <input_port name="history_size"
                  default="5"/>
      <input_port name="zero_threshold"
                  default="0.1"/>
      <input_port name="min_output_interval"
                  default="0.1"/>
      <input_port name="confidence_half_life"
                  default="1.0"/>
      <input_port name="min_confidence"
                  default="0.0"/>
      <output_port name="filtered_position"
                   default="{filtered_position}"/>
    </Action>
    <Action ID="GetLocation">
      <input_port name="topic_name"
                  default="/odometry"/>
      <output_port name="robot_location"
                   default="{robot_pose}"/>
    </Action>
    <Action ID="GoalManager">
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <input_port name="lethal_threshold"
                  default="252"/>
      <input_port name="high_cost_threshold"
                  default="200"/>
      <input_port name="visit_timeout"
                  default="30.0"/>
      <input_port name="max_retries"
                  default="2"/>
      <input_port name="reset_requested"
                  default="false"/>
      <input_port name="hysteresis_threshold"
                  default="0.7"/>
      <input_port name="arrival_distance"
                  default="0.5"/>
      <input_port name="arrival_speed"
                  default="0.2"/>
      <input_port name="stay_duration"
                  default="1.0"/>
      <input_port name="min_exclusion_radius"
                  default="2.0"/>
      <input_port name="robot_speed"
                  default="0.0"/>
      <input_port name="auto_reset_cooldown"
                  default="5.0"/>
      <input_port name="completed_point_cooldown"
                  default="10.0"/>
      <input_port name="skipped_recovery_time"
                  default="30.0"/>
      <input_port name="reached_goal_id"
                  default="{reached_goal_id}"/>
      <output_port name="best_goal"
                   default="{best_goal}"/>
      <output_port name="selected_id"
                   default="{goal_id}"/>
      <output_port name="should_reset"
                   default="{should_reset}"/>
      <output_port name="idle_count"
                   default="{idle_count}"/>
      <output_port name="done_count"
                   default="{done_count}"/>
      <output_port name="goal_statuses"
                   default="{goal_statuses}"/>
    </Action>
    <Action ID="HoldPosition">
      <input_port name="target"
                  default="{filtered_target}"/>
      <input_port name="enabled"
                  default="true"/>
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <output_port name="held_goal"
                   default="{goal}"/>
      <output_port name="is_holding"
                   default="{is_holding}"/>
    </Action>
    <Condition ID="IsStatusOK">
      <input_port name="message"
                  default="{robot_status}"/>
      <input_port name="hp_threshold"
                  default="150"/>
      <input_port name="heat_threshold"
                  default="300"/>
      <input_port name="shot_threshold"
                  default="10"/>
    </Condition>
    <Control ID="Once"
             editable="true"/>
    <Action ID="RobotControl">
      <input_port name="stop_gimbal_scan"
                  default="True"/>
      <input_port name="chassis_spin_vel"
                  default="0.0"/>
      <input_port name="gimbal_big_yaw_vel"
                  default="1.0"/>
      <input_port name="gimbal_big_yaw_angle"
                  default="0.785"/>
      <input_port name="follow_gimbal_big"
                  default="true"/>
      <input_port name="chassis_vel_multi"
                  default="1.0"/>
      <input_port name="stop_chassis_vel_multi"
                  default="True"/>
      <input_port name="track_status"
                  default="false"/>
    </Action>
    <Action ID="SendGoal">
      <input_port name="goal_pose"
                  default="{best_goal}"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="min_goal_distance"
                  default="0.5"/>
      <input_port name="current_goal_id"
                  default="{goal_id}"/>
      <output_port name="reached_goal_id"
                   default="{reached_goal_id}"/>
    </Action>
    <Action ID="SubArmors"
            editable="true">
      <input_port name="topic_name"
                  default="/detector/armors"/>
      <output_port name="armors"
                   default="{armors}"/>
    </Action>
    <Action ID="SubRobotStatus"
            editable="true">
      <input_port name="topic_name"
                  default="robot_status"/>
      <output_port name="robot_status"
                   default="{robot_status}"/>
    </Action>
  </TreeNodesModel>

</root>
