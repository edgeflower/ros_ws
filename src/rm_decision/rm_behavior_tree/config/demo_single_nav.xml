<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="SingleNav_PubTopic">
  <BehaviorTree ID="SingleNav_PubTopic">
    <ReactiveFallback>
      <IsNav2GoalNear goal_pose="{current_goal_target}"
                      global_frame="map"
                      robot_frame="chassis"
                      distance_threshold="0.5"
                      tf_timeout="0.2"/>
      <ReactiveSequence>
        <PubNav2Goal goal_pose="{main_position}"
                     frame_id="map"
                     min_pub_interval_ms="500"/>
        <WaitUntilReached goal_pose="{main_position}"
                          tolerance="0.5"/>
      </ReactiveSequence>
    </ReactiveFallback>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="IsNav2GoalNear">
      <input_port name="goal_pose"
                  default="{current_goal_target}"/>
      <input_port name="global_frame"
                  default="map"/>
      <input_port name="robot_frame"
                  default="chassis"/>
      <input_port name="distance_threshold"
                  default="0.5"/>
      <input_port name="tf_timeout"
                  default="0.2"/>
    </Condition>
    <Action ID="PubNav2Goal">
      <input_port name="goal_pose"/>
      <input_port name="frame_id"
                  default="map"/>
      <input_port name="min_pub_interval_ms"/>
    </Action>
    <Action ID="WaitUntilReached">
      <input_port name="goal_pose"/>
      <input_port name="tolerance"
                  default="0.5"/>
    </Action>
  </TreeNodesModel>

</root>
