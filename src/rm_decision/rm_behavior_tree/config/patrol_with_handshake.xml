<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="BehaviorTree">
  <BehaviorTree ID="BehaviorTree">
    <Sequence name="MainPatrolLoop">
      <GetLocation topic_name="/lidar_odometry"
                   robot_location="{robot_pose}"/>
      <GoalManager robot_pose="{robot_pose}"
                   lethal_threshold="252"
                   high_cost_threshold="200"
                   visit_timeout="30.0"
                   max_retries="2"
                   reset_requested="{reset_requested}"
                   hysteresis_threshold="0.7"
                   arrival_distance="0.5"
                   arrival_speed="0.2"
                   stay_duration="1.0"
                   min_exclusion_radius="0.1"
                   robot_speed="0.0"
                   auto_reset_cooldown="5.0"
                   completed_point_cooldown="10.0"
                   skipped_recovery_time="30.0"
                   reached_goal_id="{reached_goal_id}"
                   best_goal="{best_goal}"
                   selected_id="{goal_id}"
                   should_reset="{should_reset}"
                   idle_count="{idle_count}"
                   done_count="{done_count}"
                   goal_statuses="{goal_statuses}"/>
      <SendGoal name="NavigateToObservation"
                goal_pose="{best_goal}"
                action_name="/navigate_to_pose"
                current_goal_id="{goal_id}"
                reached_goal_id="{reached_goal_id}"/>
      <RetryUntilSuccessful num_attempts="3">
        <IsGoalReached name="VerifyGoalReached"
                       goal_id="{goal_id}"
                       goal_statuses="{goal_statuses}"
                       check_current="true"
                       current_goal_id="{goal_id}"
                       allow_approximate="false"
                       robot_pose="{robot_pose}"
                       current_goal="{best_goal}"
                       approximate_distance="0.2"/>
      </RetryUntilSuccessful>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="GetLocation">
      <input_port name="topic_name"
                  default="/odometry"/>
      <output_port name="robot_location"
                   default="{robot_pose}"/>
    </Action>
    <Action ID="GoalManager">
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <input_port name="lethal_threshold"
                  default="252"/>
      <input_port name="high_cost_threshold"
                  default="200"/>
      <input_port name="visit_timeout"
                  default="30.0"/>
      <input_port name="max_retries"
                  default="2"/>
      <input_port name="reset_requested"
                  default="false"/>
      <input_port name="hysteresis_threshold"
                  default="0.7"/>
      <input_port name="arrival_distance"
                  default="0.5"/>
      <input_port name="arrival_speed"
                  default="0.2"/>
      <input_port name="stay_duration"
                  default="1.0"/>
      <input_port name="min_exclusion_radius"
                  default="2.0"/>
      <input_port name="robot_speed"
                  default="0.0"/>
      <input_port name="auto_reset_cooldown"
                  default="5.0"/>
      <input_port name="completed_point_cooldown"
                  default="10.0"/>
      <input_port name="skipped_recovery_time"
                  default="30.0"/>
      <input_port name="reached_goal_id"
                  default="{reached_goal_id}"/>
      <output_port name="best_goal"
                   default="{best_goal}"/>
      <output_port name="selected_id"
                   default="{goal_id}"/>
      <output_port name="should_reset"
                   default="{should_reset}"/>
      <output_port name="idle_count"
                   default="{idle_count}"/>
      <output_port name="done_count"
                   default="{done_count}"/>
      <output_port name="goal_statuses"
                   default="{goal_statuses}"/>
    </Action>
    <Condition ID="IsGoalReached">
      <input_port name="goal_id"
                  default="{goal_id}"/>
      <input_port name="goal_statuses"
                  default="{goal_statuses}"/>
      <input_port name="check_current"
                  default="false"/>
      <input_port name="current_goal_id"
                  default="{goal_id}"/>
      <input_port name="allow_approximate"
                  default="false"/>
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <input_port name="current_goal"
                  default="{best_goal}"/>
      <input_port name="approximate_distance"
                  default="0.2"/>
    </Condition>
    <Action ID="SendGoal">
      <input_port name="goal_pose"
                  default="{best_goal}"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="current_goal_id"
                  default="{goal_id}"/>
      <output_port name="reached_goal_id"
                   default="{reached_goal_id}"/>
    </Action>
  </TreeNodesModel>

</root>
