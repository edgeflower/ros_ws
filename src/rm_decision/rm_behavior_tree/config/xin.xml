<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="BehaviorTree">
  <BehaviorTree ID="BehaviorTree">
    <RateController hz="0.5">
      <Sequence>
        <GetLocation topic_name="/odometry"
                     robot_location="{current_location}"/>
        <SendGoal name="SupplyArea"
                  goal_pose="2.0;0.0;0; 0;0;0;1"
                  action_name="/navigate_to_pose"/>
        <RobotControl stop_gimbal_scan="False"
                      chassis_spin_vel="0.0"
                      gimbal_big_yaw_vel="150"/>
        <SendGoal name="SupplyArea"
                  goal_pose="8.0;-0.5;0; 0;0;0;1"
                  action_name="/navigate_to_pose"/>
        <RobotControl stop_gimbal_scan="False"
                      chassis_spin_vel="0.0"
                      gimbal_big_yaw_vel="-30"/>
        <SendGoal name="SupplyArea"
                  goal_pose="0.0;0.0;0; 0;0;0;1"
                  action_name="/navigate_to_pose"/>
      </Sequence>
    </RateController>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="GetLocation"
            editable="true">
      <input_port name="topic_name"
                  default="/red_standard_robot1/lidar_odometry"/>
      <output_port name="robot_location"
                   default="{current_location}"/>
    </Action>
    <Decorator ID="RateController">
      <input_port name="hz">Rate</input_port>
    </Decorator>
    <Action ID="RobotControl"
            editable="true">
      <input_port name="stop_gimbal_scan"
                  default="True"/>
      <input_port name="chassis_spin_vel"
                  default="False"/>
      <input_port name="gimbal_big_yaw_vel"
                  default="1.0"/>
    </Action>
    <Action ID="SendGoal"
            editable="true">
      <input_port name="goal_pose"
                  default="0;0;0; 0;0;0;1"/>
      <input_port name="action_name"
                  default="/red_standard_robot1/navigate_to_pose"/>
    </Action>
  </TreeNodesModel>

</root>
