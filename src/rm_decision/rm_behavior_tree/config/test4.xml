<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="BehaviorTree">
  <BehaviorTree ID="BehaviorTree">
    <RateController hz="1">
      <Sequence>
        <GetRobotLocation robot_pose="{robot_pose}"/>
      </Sequence>
    </RateController>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="GetRobotLocation"
            editable="true">
      <output_port name="robot_pose"
                   default="{robot_pose}"/>
    </Action>
    <Decorator ID="RateController">
      <input_port name="hz">Rate</input_port>
    </Decorator>
  </TreeNodesModel>

</root>
