<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="BehaviorTree">
  <BehaviorTree ID="BehaviorTree">
    <RateController hz="1">
      <Sequence>
        <SubAllRobotLocation topic_name="all_robot_location"
                             all_robot_location="{all_robot_location}"/>
      </Sequence>
    </RateController>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Decorator ID="RateController">
      <input_port name="hz">Rate</input_port>
    </Decorator>
    <Action ID="SubAllRobotLocation">
      <input_port name="topic_name"
                  default="all_robot_location"/>
      <output_port name="all_robot_location"
                   default="{all_robot_location}"/>
    </Action>
  </TreeNodesModel>

</root>
