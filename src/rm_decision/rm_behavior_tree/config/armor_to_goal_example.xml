<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="armor_to_goal_main">
  <BehaviorTree ID="armor_to_goal_main">
    <ReactiveSequence name="ArmorTrackingLoop">
      <SubTargetTopic name="SubscribeTarget"
                      topic_name="/target_tracking"
                      target_message="{target_message}"/>
      <ArmorToGoal name="CalculateGoal"
                   target_message="{target_message}"
                   robot_pose="{robot_pose}"
                   offset_distance="2.0"
                   predict_time="0.5"
                   max_chase_distance="10.0"
                   goal_pose="{goal}"/>
      <SendGoal name="NavigateToEnemy"
                goal_pose="{goal}"
                action_name="/navigate_to_pose"
                current_goal_id="{goal_id}"
                reached_goal_id="{reached_goal_id}"/>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="armor_to_goal_simple">
    <Sequence>
      <SubTargetTopic topic_name="/target_tracking"
                      target_message="{target_message}"/>
      <ArmorToGoal target_message="{target_message}"
                   robot_pose="{robot_pose}"
                   offset_distance="2.0"
                   predict_time="0.5"
                   max_chase_distance="10.0"
                   goal_pose="{goal}"/>
      <SendGoal goal_pose="{goal}"
                action_name="/navigate_to_pose"
                current_goal_id="{goal_id}"
                reached_goal_id="{reached_goal_id}"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="armor_to_goal_with_filter">
    <Sequence>
      <SubTargetTopic topic_name="/target_tracking"
                      target_message="{target_message}"/>
      <EnemyPositionFilter enemy_position="{target_message}"
                           alpha="0.3"
                           max_distance="1.5"
                           history_size="5"
                           zero_threshold="0.1"
                           min_output_interval="0.1"
                           confidence_half_life="1.0"
                           min_confidence="0.0"
                           filtered_position="{filtered_target}"/>
      <ConfidenceHysteresis target="{filtered_target}"
                            upper_threshold="0.5"
                            lower_threshold="0.3"
                            grace_period="1.5"
                            enable_hold_position="true"
                            current_confidence="{current_confidence}"
                            hysteresis_state="{hysteresis_state}"/>
      <CheckHysteresisState state="{hysteresis_state}"
                            expected_state="HIGH"/>
      <ArmorToGoal target_message="{filtered_target}"
                   robot_pose="{robot_pose}"
                   offset_distance="2.0"
                   predict_time="0.5"
                   max_chase_distance="10.0"
                   goal_pose="{goal}"/>
      <SendGoal goal_pose="{goal}"
                action_name="/navigate_to_pose"
                current_goal_id="{goal_id}"
                reached_goal_id="{reached_goal_id}"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ArmorToGoal">
      <input_port name="target_message"
                  default="{target_message}"/>
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <input_port name="offset_distance"
                  default="2.0"/>
      <input_port name="predict_time"
                  default="0.5"/>
      <input_port name="max_chase_distance"
                  default="10.0"/>
      <output_port name="goal_pose"
                   default="{goal}"/>
    </Action>
    <Condition ID="CheckHysteresisState">
      <input_port name="state"
                  default="{hysteresis_state}"/>
      <input_port name="expected_state"
                  default="HIGH"/>
    </Condition>
    <Condition ID="ConfidenceHysteresis">
      <input_port name="target"
                  default="{filtered_target}"/>
      <input_port name="upper_threshold"
                  default="0.4"/>
      <input_port name="lower_threshold"
                  default="0.3"/>
      <input_port name="grace_period"
                  default="1.5"/>
      <input_port name="enable_hold_position"
                  default="true"/>
      <output_port name="current_confidence"
                   default="{current_confidence}"/>
      <output_port name="hysteresis_state"
                   default="{hysteresis_state}"/>
    </Condition>
    <Action ID="EnemyPositionFilter"
            editable="true">
      <input_port name="enemy_position"
                  default="{armors}"/>
      <input_port name="alpha"
                  default="0.3"/>
      <input_port name="max_distance"
                  default="1.5"/>
      <input_port name="history_size"
                  default="5"/>
      <input_port name="zero_threshold"
                  default="0.1"/>
      <input_port name="min_output_interval"
                  default="0.1"/>
      <input_port name="confidence_half_life"
                  default="1.0"/>
      <input_port name="min_confidence"
                  default="0.0"/>
      <output_port name="filtered_position"
                   default="{filtered_position}"/>
    </Action>
    <Action ID="SendGoal">
      <input_port name="goal_pose"
                  default="{best_goal}"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="current_goal_id"
                  default="{goal_id}"/>
      <output_port name="reached_goal_id"
                   default="{reached_goal_id}"/>
    </Action>
    <Action ID="SubTargetTopic">
      <input_port name="topic_name"
                  default="/target_tracking"/>
      <output_port name="target_message"
                   default="{target_message}"/>
    </Action>
  </TreeNodesModel>

</root>
