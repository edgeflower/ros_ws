<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="RMUL2026_fang">
  <BehaviorTree ID="RMUL2026_fang">
    <ReactiveSequence>
      <SubRobotAreaStatus topic_name="/robot_area_status"
                          robot_area_status="{robot_area_status}"/>
      <SubRobotStatus topic_name="/robot_status"
                      robot_status="{robot_status}"/>
      <SubGameStatus topic_name="/game_status"
                     game_status="{game_status}"/>
      <SubArmors topic_name="/target_tracking"
                 armors="{armors}"/>
      <GetLocation topic_name="/chassis_odometry_gt"
                   robot_location="{robot_pose}"/>
      <EnemyPositionFilter enemy_position="{armors}"
                           alpha="0.2"
                           max_distance="1.0"
                           history_size="7"
                           zero_threshold="0.1"
                           min_output_interval="0.1"
                           confidence_half_life="1.0"
                           min_confidence="0.0"
                           filtered_position="{filtered_target}"/>
      <ConfidenceHysteresis target="{filtered_target}"
                            upper_threshold="0.5"
                            lower_threshold="0.2"
                            grace_period="2.5"
                            enable_hold_position="true"
                            current_confidence="{current_confidence}"
                            hysteresis_state="{hysteresis_state}"/>
      <AsyncFallback>
        <IsGameTime message="{game_status}"
                    game_progress="4"
                    lower_remain_time="0"
                    higher_remain_time="100000"/>
        <IsAttacked message="{robot_status}"/>
      </AsyncFallback>
      <IfThenElse>
        <Fallback>
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="HIGH"/>
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="GRACE_PERIOD"/>
        </Fallback>
        <Script code="combat_mode := true"/>
        <Script code="combat_mode := false"/>
      </IfThenElse>
      <IfThenElse>
        <IsRobotInArea robot_area_status="{robot_area_status}"
                       target_area_name="central_highland"
                       target_area_type="protect"/>
        <Script code="through_mode := true"/>
        <Script code="through_mode := false"/>
      </IfThenElse>
      <IfThenElse>
        <IsRobotInArea robot_area_status="{robot_area_status}"
                       target_area_name="bumpy_area"
                       target_area_type="protect"/>
        <Script code="in_bumpy_area := true"/>
        <Script code="in_bumpy_area := false"/>
      </IfThenElse>
      <IfThenElse>
        <Inverter>
          <IsStatusOK message="{robot_status}"
                      hp_threshold="160"
                      heat_threshold="0"
                      shot_threshold="0"/>
        </Inverter>
        <Script code="status_bad := true"/>
        <Script code="status_bad := false"/>
      </IfThenElse>
      <ReactiveFallback name="ModeSelector">
        <ReactiveSequence name="BumpyRoadProtection">
          <ScriptCondition code="in_bumpy_area == true &amp;&amp; status_bad == true"/>
          <IsRobotInArea robot_area_status="{robot_area_status}"
                         target_area_name="bumpy_area"
                         target_area_type="protect"/>
          <IsYawInRange robot_pose="{robot_pose}"
                        min_yaw_deg="-90"
                        max_yaw_deg="90"/>
          <RobotControl stop_gimbal_scan="True"
                        chassis_spin_vel="0.0"
                        gimbal_big_yaw_vel="0.0"
                        gimbal_big_yaw_angle="0.0"
                        follow_gimbal_big="true"
                        chassis_vel_multi="1.0"
                        stop_chassis_vel_multi="True"
                        track_status="True"
                        perception_status="False"/>
          <LoadWaypoints waypoint_file="/home/lu/ros_ws/前哨站.csv"
                         frame_id="map"
                         waypoints="{waypoints_target}"
                         wait_times="{wait_times_target}"
                         total_waypoints="{total_wp_target}"
                         wp_idx="{wp_idx_target}"/>
          <GetCurrentWaypoint waypoints="{waypoints_target}"
                              wait_times="{wait_times_target}"
                              wp_idx="{wp_idx_target}"
                              current_goal="{current_goal_target}"
                              current_wait_sec="{current_wait_target}"/>
          <ReactiveFallback name="GoOutpostUntilNear">
            <Sequence>
              <WaitUntilReached goal_pose="{current_goal_target}"
                                tolerance="0.1"/>
              <CancelNav2Goal action_name="/navigate_to_pose"
                              timeout="1.0"/>
            </Sequence>
            <SendNav2Goal goal_pose="{current_goal_target}"
                          action_name="/navigate_to_pose"
                          min_distance="0.1"/>
          </ReactiveFallback>
          <Wait duration="5"/>
        </ReactiveSequence>
        <ReactiveSequence>
          <Inverter>
            <IsStatusOK message="{robot_status}"
                        hp_threshold="160"
                        heat_threshold="0"
                        shot_threshold="10"/>
          </Inverter>
          <ForceSuccess>
            <Sequence>
              <RobotControl stop_gimbal_scan="True"
                            chassis_spin_vel="0.0"
                            gimbal_big_yaw_vel="0.0"
                            gimbal_big_yaw_angle="0.0"
                            follow_gimbal_big="true"
                            chassis_vel_multi="1.0"
                            stop_chassis_vel_multi="True"
                            track_status="True"
                            perception_status="False"/>
              <LoadWaypoints waypoint_file="/home/lu/ros_ws/回家.csv"
                             frame_id="map"
                             waypoints="{waypoints}"
                             wait_times="{wait_times}"
                             total_waypoints="{total_wp}"
                             wp_idx="{wp_idx}"/>
              <GetCurrentWaypoint waypoints="{waypoints}"
                                  wait_times="{wait_times}"
                                  wp_idx="{wp_idx}"
                                  current_goal="{current_goal_home}"
                                  current_wait_sec="{current_wait}"/>
              <PubNav2Goal goal_pose="{current_goal_home}"
                           frame_id="map"
                           min_pub_interval_ms="500"/>
              <WaitUntilReached goal_pose="{out_robot_pose_home}"
                                tolerance="0.5"/>
              <Wait duration="5"/>
            </Sequence>
          </ForceSuccess>
        </ReactiveSequence>
        <ReactiveSequence>
          <ScriptCondition code="combat_mode == true"/>
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="HIGH"/>
          <RobotControl stop_gimbal_scan="True"
                        chassis_spin_vel="0.0"
                        gimbal_big_yaw_vel="0.0"
                        gimbal_big_yaw_angle="0.0"
                        follow_gimbal_big="false"
                        chassis_vel_multi="1.0"
                        stop_chassis_vel_multi="True"
                        track_status="false"
                        perception_status="True"/>
          <ArmorToGoal target_message="{filtered_target}"
                       robot_pose="{robot_pose}"
                       offset_distance="2.0"
                       predict_time="0.5"
                       max_chase_distance="10.0"
                       goal_pose="{attack_goal}"/>
          <ReactiveFallback name="GoOutpostUntilNear">
            <ChaseGoal goal_pose="{attack_goal}"
                       action_name="/navigate_to_pose"
                       min_goal_distance="0.3"
                       max_resend_interval="2.0"
                       chase_timeout="15.0"
                       server_timeout="5.0"
                       stop_distance="1.5"/>
            <Sequence>
              <WaitUntilReached goal_pose="{attack_goal}"
                                tolerance="2.0"/>
              <CancelNav2Goal action_name="/navigate_to_pose"
                              timeout="1.0"/>
            </Sequence>
          </ReactiveFallback>
        </ReactiveSequence>
        <ReactiveSequence>
          <ScriptCondition code="combat_mode == true"/>
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="GRACE_PERIOD"/>
          <RobotControl stop_gimbal_scan="True"
                        chassis_spin_vel="0.0"
                        gimbal_big_yaw_vel="0.0"
                        gimbal_big_yaw_angle="0.0"
                        follow_gimbal_big="false"
                        chassis_vel_multi="1.0"
                        stop_chassis_vel_multi="True"
                        track_status="false"
                        perception_status="True"/>
          <HoldPosition target="{filtered_target}"
                        enabled="true"
                        robot_pose="{robot_pose}"
                        held_goal="{hold_goal}"
                        is_holding="{is_holding}"/>
          <ReactiveFallback name="GoOutpostUntilNear">
            <SendGoal goal_pose="{hold_goal}"
                      action_name="/navigate_to_pose"
                      current_goal_id="-2"
                      reached_goal_id="{hold_reached_goal_id}"/>
            <Sequence>
              <WaitUntilReached goal_pose="{hold_goal}"
                                tolerance="2.0"/>
              <CancelNav2Goal action_name="/navigate_to_pose"
                              timeout="1.0"/>
            </Sequence>
          </ReactiveFallback>
        </ReactiveSequence>
        <ReactiveSequence>
          <CheckHysteresisState state="{hysteresis_state}"
                                expected_state="LOW"/>
          <WhileDoElse>
            <ScriptCondition code="through_mode == true"/>
            <Sequence>
              <RobotControl stop_gimbal_scan="True"
                            chassis_spin_vel="0.0"
                            gimbal_big_yaw_vel="0.0"
                            gimbal_big_yaw_angle="0.0"
                            follow_gimbal_big="False"
                            chassis_vel_multi="1.0"
                            stop_chassis_vel_multi="True"
                            track_status="False"
                            perception_status="True"/>
              <LoadWaypoints waypoint_file="/home/lu/ros_ws/中央高地巡逻.csv"
                             frame_id="map"
                             waypoints="{waypoints_high}"
                             wait_times="{wait_times_high}"
                             total_waypoints="{total_wp_high}"
                             wp_idx="{wp_idx_high}"/>
              <KeepRunningUntilFailure>
                <Sequence>
                  <GetCurrentWaypoint waypoints="{waypoints_high}"
                                      wait_times="{wait_times_high}"
                                      wp_idx="{wp_idx_high}"
                                      current_goal="{current_goal_high}"
                                      current_wait_sec="{current_wait_sec_high}"/>
                  <ReactiveSequence>
                    <PubNav2Goal goal_pose="{current_goal_high}"
                                 frame_id="map"
                                 min_pub_interval_ms="500"/>
                    <WaitUntilReached goal_pose="{current_goal_high}"
                                      tolerance="0.5"/>
                  </ReactiveSequence>
                  <WaitDuration duration_sec="{current_wait_sec_high}"/>
                  <NextWaypoint wp_idx="{wp_idx_high}"
                                total_waypoints="{total_wp_high}"/>
                </Sequence>
              </KeepRunningUntilFailure>
            </Sequence>
            <Sequence>
              <RobotControl stop_gimbal_scan="True"
                            chassis_spin_vel="0.0"
                            gimbal_big_yaw_vel="0.0"
                            gimbal_big_yaw_angle="0.0"
                            follow_gimbal_big="true"
                            chassis_vel_multi="1.0"
                            stop_chassis_vel_multi="True"
                            track_status="True"
                            perception_status="False"/>
              <LoadWaypoints waypoint_file="/home/lu/ros_ws/上中央高地.csv"
                             frame_id="map"
                             waypoints="{waypoints}"
                             wait_times="{wait_times}"
                             total_waypoints="{total_wp}"
                             wp_idx="{wp_idx}"/>
              <ReactiveSequence>
                <GetCurrentWaypoint waypoints="{waypoints}"
                                    wait_times="{wait_times}"
                                    wp_idx="{wp_idx}"
                                    current_goal="{current_goal}"
                                    current_wait_sec="{current_wait_sec}"/>
                <PubNav2Goal goal_pose="{current_goal}"
                             frame_id="map"
                             min_pub_interval_ms="500"/>
                <WaitUntilReached goal_pose="{current_goal}"
                                  tolerance="0.5"/>
              </ReactiveSequence>
            </Sequence>
          </WhileDoElse>
        </ReactiveSequence>
      </ReactiveFallback>
    </ReactiveSequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ArmorToGoal">
      <input_port name="target_message"
                  default="{target_message}"/>
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <input_port name="offset_distance"
                  default="2.0"/>
      <input_port name="predict_time"
                  default="0.5"/>
      <input_port name="max_chase_distance"
                  default="10.0"/>
      <output_port name="goal_pose"
                   default="{goal}"/>
    </Action>
    <Action ID="CancelNav2Goal">
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="timeout"
                  default="1.0"/>
    </Action>
    <Action ID="ChaseGoal">
      <input_port name="goal_pose"
                  default="{attack_goal}"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="min_goal_distance"
                  default="0.3"/>
      <input_port name="max_resend_interval"
                  default="2.0"/>
      <input_port name="chase_timeout"
                  default="15.0"/>
      <input_port name="server_timeout"
                  default="5.0"/>
      <input_port name="stop_distance"
                  default="1.5"/>
    </Action>
    <Condition ID="CheckHysteresisState">
      <input_port name="state"
                  default="{hysteresis_state}"/>
      <input_port name="expected_state"
                  default="HIGH"/>
    </Condition>
    <Condition ID="ConfidenceHysteresis">
      <input_port name="target"
                  default="{filtered_target}"/>
      <input_port name="upper_threshold"
                  default="0.4"/>
      <input_port name="lower_threshold"
                  default="0.3"/>
      <input_port name="grace_period"
                  default="1.5"/>
      <input_port name="enable_hold_position"
                  default="true"/>
      <output_port name="current_confidence"
                   default="{current_confidence}"/>
      <output_port name="hysteresis_state"
                   default="{hysteresis_state}"/>
    </Condition>
    <Action ID="EnemyPositionFilter"
            editable="true">
      <input_port name="enemy_position"
                  default="{armors}"/>
      <input_port name="alpha"
                  default="0.3"/>
      <input_port name="max_distance"
                  default="1.5"/>
      <input_port name="history_size"
                  default="5"/>
      <input_port name="zero_threshold"
                  default="0.1"/>
      <input_port name="min_output_interval"
                  default="0.1"/>
      <input_port name="confidence_half_life"
                  default="1.0"/>
      <input_port name="min_confidence"
                  default="0.0"/>
      <output_port name="filtered_position"
                   default="{filtered_position}"/>
    </Action>
    <Action ID="GetCurrentWaypoint">
      <input_port name="waypoints"
                  default="{waypoints}"/>
      <input_port name="wait_times"
                  default="{wait_times}"/>
      <input_port name="wp_idx"
                  default="{wp_idx}"/>
      <output_port name="current_goal"
                   default="{current_goal}"/>
      <output_port name="current_wait_sec"
                   default="{current_wait}"/>
    </Action>
    <Action ID="GetLocation">
      <input_port name="topic_name"
                  default="/odometry"/>
      <output_port name="robot_location"
                   default="{robot_pose}"/>
    </Action>
    <Action ID="HoldPosition">
      <input_port name="target"
                  default="{filtered_target}"/>
      <input_port name="enabled"
                  default="true"/>
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <output_port name="held_goal"
                   default="{goal}"/>
      <output_port name="is_holding"
                   default="{is_holding}"/>
    </Action>
    <Action ID="IsAttacked"
            editable="true">
      <input_port name="message"
                  default="{robot_status}"/>
    </Action>
    <Condition ID="IsGameTime"
               editable="true">
      <input_port name="message"
                  default="{game_status}"/>
      <input_port name="game_progress"
                  default="4"/>
      <input_port name="lower_remain_time"
                  default="0"/>
      <input_port name="higher_remain_time"
                  default="300"/>
    </Condition>
    <Condition ID="IsRobotInArea"
               editable="true">
      <input_port name="robot_area_status"
                  default="{robot_area_status}"/>
      <input_port name="target_area_name"/>
      <input_port name="target_area_type"/>
    </Condition>
    <Condition ID="IsStatusOK"
               editable="true">
      <input_port name="message"
                  default="{robot_status}"/>
      <input_port name="hp_threshold"
                  default="100"/>
      <input_port name="heat_threshold"
                  default="350"/>
      <input_port name="shot_threshold"
                  default="0"/>
    </Condition>
    <Condition ID="IsYawInRange">
      <input_port name="robot_pose"
                  default="{robot_pose}"/>
      <input_port name="min_yaw_deg"
                  default="-180.0"/>
      <input_port name="max_yaw_deg"
                  default="180.0"/>
    </Condition>
    <Action ID="LoadWaypoints">
      <input_port name="waypoint_file"/>
      <input_port name="frame_id"
                  default="map"/>
      <output_port name="waypoints"
                   default="{waypoints}"/>
      <output_port name="wait_times"
                   default="{wait_times}"/>
      <output_port name="total_waypoints"
                   default="{total_wp}"/>
      <output_port name="wp_idx"
                   default="{wp_idx}"/>
    </Action>
    <Action ID="NextWaypoint">
      <inout_port name="wp_idx"
                  default="{wp_idx}"/>
      <input_port name="total_waypoints"
                  default="{total_wp}"/>
    </Action>
    <Action ID="PubNav2Goal">
      <input_port name="goal_pose"/>
      <input_port name="frame_id"
                  default="map"/>
      <input_port name="min_pub_interval_ms"/>
    </Action>
    <Action ID="RobotControl">
      <input_port name="stop_gimbal_scan"
                  default="True"/>
      <input_port name="chassis_spin_vel"
                  default="0.0"/>
      <input_port name="gimbal_big_yaw_vel"
                  default="1.0"/>
      <input_port name="gimbal_big_yaw_angle"
                  default="0.785"/>
      <input_port name="follow_gimbal_big"
                  default="true"/>
      <input_port name="chassis_vel_multi"
                  default="1.0"/>
      <input_port name="stop_chassis_vel_multi"
                  default="True"/>
      <input_port name="track_status"
                  default="false"/>
      <input_port name="perception_status"
                  default="True"/>
    </Action>
    <Action ID="SendGoal">
      <input_port name="goal_pose"
                  default="{best_goal}"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="current_goal_id"
                  default="{goal_id}"/>
      <output_port name="reached_goal_id"
                   default="{reached_goal_id}"/>
    </Action>
    <Action ID="SendNav2Goal">
      <input_port name="goal_pose"/>
      <input_port name="action_name"
                  default="/navigate_to_pose"/>
      <input_port name="min_distance"
                  default="0.5"/>
    </Action>
    <Action ID="SubArmors"
            editable="true">
      <input_port name="topic_name"
                  default="/detector/armors"/>
      <output_port name="armors"
                   default="{armors}"/>
    </Action>
    <Action ID="SubGameStatus"
            editable="true">
      <input_port name="topic_name"
                  default="game_status"/>
      <output_port name="game_status"
                   default="{game_status}"/>
    </Action>
    <Action ID="SubRobotAreaStatus"
            editable="true">
      <input_port name="topic_name"
                  default="/area_status"/>
      <output_port name="robot_area_status"
                   default="{robot_area_status}"/>
    </Action>
    <Action ID="SubRobotStatus"
            editable="true">
      <input_port name="topic_name"
                  default="robot_status"/>
      <output_port name="robot_status"
                   default="{robot_status}"/>
    </Action>
    <Action ID="Wait"
            editable="true">
      <input_port name="duration"
                  default="3"/>
    </Action>
    <Action ID="WaitDuration">
      <input_port name="duration_sec"
                  default="5.0"/>
    </Action>
    <Action ID="WaitUntilReached">
      <input_port name="goal_pose"/>
      <input_port name="tolerance"
                  default="0.5"/>
    </Action>
  </TreeNodesModel>

</root>
