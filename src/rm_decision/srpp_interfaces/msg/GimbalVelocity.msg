# ============================================
# GimbalVelocity.msg
# 云台速度控制参数
# ============================================

float32 pitch             # pitch 角速度 (rad/s)
float32 yaw               # yaw 角速度 (rad/s)

float32 pitch_min_range   # pitch 最小角 (rad)
float32 pitch_max_range   # pitch 最大角 (rad)
float32 yaw_min_range     # yaw 最小角 (rad)
float32 yaw_max_range     # yaw 最大角 (rad)

